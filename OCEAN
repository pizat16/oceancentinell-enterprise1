  outline:none;transition:border-color 0.15s;
}
.ws-form-row input:focus,.ws-form-row select:focus{border-color:rgba(0,212,255,0.5);box-shadow:var(--focus)}
.ws-chips{display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.7rem}
.ws-chip{padding:0.25rem 0.65rem;border-radius:999px;border:1px solid rgba(0,212,255,0.25);background:rgba(0,212,255,0.06);font-size:0.67rem;color:var(--cyan-300);font-family:'Rajdhani',sans-serif}
.ws-actions{display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:0.6rem}
.ws-log{
