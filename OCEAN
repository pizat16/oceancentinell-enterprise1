<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<meta name="color-scheme" content="dark"/>
<meta name="description" content="OceanCentinell ENTERPRISE — Maritime Cybersecurity Command Platform by Beacon of the Eagle LLC"/>
<title>OceanCentinell ENTERPRISE · Beacon of the Eagle</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Oxanium:wght@300;400;600;700;800&family=IBM+Plex+Mono:wght@300;400;500;600&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --navy-950:#020c1b;--navy-900:#0a1628;--navy-800:#0d2240;--navy-700:#0f3460;
  --ocean-600:#1a5276;--cyan-500:#00d4ff;--cyan-400:#38bdf8;--cyan-300:#7dd3fc;
  --teal-400:#2dd4bf;--teal-300:#5eead4;--green-400:#34d399;--green-300:#6ee7b7;
  --amber-400:#fbbf24;--red-400:#f87171;--rose-400:#fb7185;
  --gold-400:#f59e0b;--gold-300:#fcd34d;
  --text:#e8f4fd;--muted:#64748b;--muted-bright:#94a3b8;
  --card-bg:rgba(10,22,40,0.88);--card-border:rgba(0,212,255,0.13);
  --card-border-hover:rgba(0,212,255,0.32);
  --radius:18px;--radius-sm:10px;
  --focus:0 0 0 3px rgba(0,212,255,0.4);
  --shadow-card:0 8px 32px rgba(0,0,0,0.45),0 1px 0 rgba(0,212,255,0.08) inset;
  --shadow-glow:0 0 40px rgba(0,212,255,0.1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{font-family:'IBM Plex Mono',monospace;background:var(--navy-950);color:var(--text);overflow-x:hidden;scroll-behavior:smooth}
#ocean-canvas{position:fixed;inset:0;z-index:0;pointer-events:none;opacity:0.5}
.grid-overlay{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(0,212,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(0,212,255,0.02) 1px,transparent 1px);background-size:60px 60px;opacity:0.6}
.layout{position:relative;z-index:1;max-width:1900px;margin:0 auto;padding:1.5rem 2rem 2rem}

/* ─── CLASSIFIED BANNER ─── */
.classified-bar{
  background:linear-gradient(90deg,rgba(251,191,36,0.12),rgba(251,191,36,0.06),rgba(251,191,36,0.12));
  border:1px solid rgba(251,191,36,0.3);
  border-radius:6px;
  padding:0.4rem 1rem;
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
  margin-bottom:0.9rem;
  font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;
  color:var(--gold-400);
  font-family:'Rajdhani',sans-serif;font-weight:600;
  animation:slideDown 0.4s ease both;
}
.classified-bar span{display:flex;align-items:center;gap:0.5rem}

/* ─── HEADER ─── */
.header{
  display:flex;align-items:center;justify-content:space-between;gap:1.5rem;flex-wrap:wrap;
  padding:1.6rem 2rem;
  background:linear-gradient(135deg,rgba(10,22,40,0.98) 0%,rgba(15,52,96,0.92) 60%,rgba(10,22,40,0.98) 100%);
  border:1px solid rgba(0,212,255,0.22);
  border-radius:var(--radius);
  box-shadow:var(--shadow-card),var(--shadow-glow),0 0 0 1px rgba(0,212,255,0.04) inset;
  backdrop-filter:blur(24px);
  animation:slideDown 0.6s cubic-bezier(0.16,1,0.3,1) both;
  position:relative;overflow:hidden;
}
.header::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent 0%,rgba(0,212,255,0.6) 30%,rgba(45,212,191,0.8) 50%,rgba(0,212,255,0.6) 70%,transparent 100%);
}
.header::after{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 20% 50%,rgba(0,212,255,0.04) 0%,transparent 60%);
  pointer-events:none;
}
@keyframes slideDown{from{opacity:0;transform:translateY(-18px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}

.header-brand{display:flex;align-items:center;gap:1.2rem}
.eagle-emblem{
  width:62px;height:62px;flex-shrink:0;
  background:radial-gradient(circle at 35% 30%,rgba(0,212,255,0.15),rgba(10,22,40,0.95));
  border:1.5px solid rgba(0,212,255,0.4);
  border-radius:14px;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 0 24px rgba(0,212,255,0.2),inset 0 0 12px rgba(0,212,255,0.05);
  animation:pulse-ring 3.5s ease-in-out infinite;
}
@keyframes pulse-ring{
  0%,100%{box-shadow:0 0 24px rgba(0,212,255,0.2),inset 0 0 12px rgba(0,212,255,0.05)}
  50%{box-shadow:0 0 40px rgba(0,212,255,0.4),inset 0 0 18px rgba(0,212,255,0.1)}
}
.eagle-emblem svg{width:40px;height:40px}
.brand-stack{display:flex;flex-direction:column;gap:0.1rem}
.brand-company{
  font-family:'Rajdhani',sans-serif;font-size:0.72rem;font-weight:600;
  letter-spacing:0.2em;text-transform:uppercase;
  color:var(--gold-300);opacity:0.85;
}
.brand-product{
  font-family:'Oxanium',sans-serif;font-size:clamp(1.5rem,2.4vw,2.2rem);font-weight:800;
  letter-spacing:0.03em;line-height:1;
  background:linear-gradient(90deg,#e8f4fd 0%,var(--cyan-500) 55%,var(--teal-300) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.brand-tagline{
  font-size:0.68rem;color:var(--muted-bright);letter-spacing:0.08em;
  text-transform:uppercase;margin-top:0.2rem;
  font-family:'Rajdhani',sans-serif;font-weight:500;
}
.header-center{
  display:flex;flex-direction:column;align-items:center;gap:0.3rem;
}
.threat-level-box{
  display:flex;align-items:center;gap:0.6rem;
  padding:0.5rem 1.2rem;
  border-radius:8px;
  background:rgba(248,113,113,0.1);border:1px solid rgba(248,113,113,0.3);
}
.threat-level-label{font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);font-family:'Rajdhani',sans-serif}
.threat-level-val{
  font-family:'Oxanium',sans-serif;font-size:1rem;font-weight:800;
  color:var(--amber-400);letter-spacing:0.08em;
}
.header-right{display:flex;align-items:center;gap:1rem;flex-wrap:wrap}
.live-badge{
  display:flex;align-items:center;gap:0.5rem;
  padding:0.45rem 1rem;border-radius:999px;
  background:rgba(52,211,153,0.1);border:1px solid rgba(52,211,153,0.4);
  font-size:0.7rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--green-400);
  font-family:'Rajdhani',sans-serif;
}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--green-400);animation:ping 1.5s ease-out infinite}
@keyframes ping{0%{box-shadow:0 0 0 0 rgba(52,211,153,0.6)}70%{box-shadow:0 0 0 8px rgba(52,211,153,0)}100%{box-shadow:0 0 0 0 rgba(52,211,153,0)}}
.header-clock{font-family:'IBM Plex Mono',monospace;font-size:0.78rem;color:var(--cyan-400);opacity:0.85;text-align:right;line-height:1.4}
.clock-date{font-size:0.62rem;color:var(--muted);display:block}
.tos-btn{
  padding:0.35rem 0.8rem;border-radius:6px;
  background:rgba(251,191,36,0.08);border:1px solid rgba(251,191,36,0.25);
  color:var(--gold-300);font-size:0.65rem;letter-spacing:0.08em;font-family:'Rajdhani',sans-serif;
  cursor:pointer;font-weight:600;text-transform:uppercase;transition:all 0.15s;
}
.tos-btn:hover{background:rgba(251,191,36,0.15);border-color:rgba(251,191,36,0.5)}

/* ─── PLAN STRIP ─── */
.plan-strip{display:flex;gap:0.6rem;flex-wrap:wrap;margin-top:1rem;animation:fadeUp 0.7s 0.1s cubic-bezier(0.16,1,0.3,1) both}
.plan-tab{
  flex:1;min-width:200px;padding:0.9rem 1.2rem;
  border-radius:var(--radius-sm);background:var(--card-bg);
  border:1px solid var(--card-border);cursor:pointer;transition:all 0.2s ease;text-align:left;
  position:relative;overflow:hidden;
}
.plan-tab::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(0,212,255,0.4),transparent);opacity:0;transition:opacity 0.2s}
.plan-tab:hover::before,.plan-tab.active::before{opacity:1}
.plan-tab:hover{border-color:var(--card-border-hover);background:rgba(0,212,255,0.05)}
.plan-tab.active{background:linear-gradient(135deg,rgba(0,212,255,0.15),rgba(45,212,191,0.08));border-color:rgba(0,212,255,0.5)}
.plan-tab-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:0.3rem}
.plan-tab-name{font-family:'Oxanium',sans-serif;font-weight:700;font-size:0.85rem;color:var(--text)}
.plan-tab.active .plan-tab-name{color:var(--cyan-400)}
.plan-price{font-family:'Oxanium',sans-serif;font-weight:800;font-size:0.78rem;color:var(--teal-400)}
.plan-tab-desc{font-size:0.67rem;color:var(--muted);margin-top:0.1rem;font-family:'Rajdhani',sans-serif}

/* ─── MAIN GRID ─── */
.main-grid{display:grid;grid-template-columns:1fr 430px;gap:1rem;margin-top:1rem;animation:fadeUp 0.7s 0.2s cubic-bezier(0.16,1,0.3,1) both}
.card{
  background:var(--card-bg);border:1px solid var(--card-border);
  border-radius:var(--radius);padding:1.5rem;
  box-shadow:var(--shadow-card);backdrop-filter:blur(18px);
}
.section-label{
  font-family:'Rajdhani',sans-serif;font-size:0.68rem;font-weight:600;
  letter-spacing:0.14em;text-transform:uppercase;color:var(--cyan-400);opacity:0.75;margin-bottom:0.9rem;
  display:flex;align-items:center;gap:0.5rem;
}
.section-label::before{content:'';display:inline-block;width:16px;height:1px;background:var(--cyan-400);opacity:0.5}

/* ─── METRICS ─── */
.metrics-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0.8rem}
.metric-card{
  background:linear-gradient(145deg,rgba(15,52,96,0.4),rgba(10,22,40,0.7));
  border:1px solid rgba(0,212,255,0.1);border-radius:14px;padding:1.2rem 1rem;
  cursor:pointer;transition:all 0.18s ease;position:relative;overflow:hidden;
}
.metric-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,rgba(0,212,255,0.3),transparent);opacity:0;transition:opacity 0.2s}
.metric-card:hover::after,.metric-card.active::after{opacity:1}
.metric-card:hover{border-color:rgba(0,212,255,0.3);transform:translateY(-2px);background:linear-gradient(145deg,rgba(0,212,255,0.08),rgba(10,22,40,0.75))}
.metric-card.active{border-color:rgba(0,212,255,0.5);background:linear-gradient(145deg,rgba(0,212,255,0.12),rgba(10,22,40,0.75))}
.metric-icon-wrap{width:34px;height:34px;border-radius:9px;background:rgba(0,212,255,0.1);display:flex;align-items:center;justify-content:center;margin-bottom:0.7rem}
.metric-icon-wrap svg{width:17px;height:17px;stroke:var(--cyan-400);fill:none;stroke-width:1.8}
.metric-value{font-family:'Oxanium',sans-serif;font-size:clamp(1.6rem,2vw,2.2rem);font-weight:800;color:var(--cyan-400);letter-spacing:-0.02em;line-height:1}
.metric-value.risk-low{color:var(--green-400)}.metric-value.risk-medium{color:var(--amber-400)}.metric-value.risk-high{color:var(--red-400)}.metric-value.risk-crit{color:var(--rose-400)}
.metric-label{font-size:0.67rem;color:var(--muted-bright);text-transform:uppercase;letter-spacing:0.1em;margin-top:0.3rem;font-family:'Rajdhani',sans-serif}
.metric-delta{font-size:0.63rem;color:var(--muted);margin-top:0.1rem}

/* ─── CHART ROW ─── */
.chart-row{display:grid;grid-template-columns:1fr 1fr;gap:0.8rem;margin-top:0.8rem}
.chart-panel{padding:0.9rem;background:rgba(2,12,27,0.85);border:1px solid rgba(0,212,255,0.1);border-radius:var(--radius-sm)}
.chart-panel-title{font-family:'Rajdhani',sans-serif;font-weight:600;font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted-bright);margin-bottom:0.6rem;display:flex;justify-content:space-between;align-items:center}
canvas.chart-canvas{width:100%!important;max-height:90px}

/* ─── METRIC DETAIL ─── */
.metric-detail-panel{
  margin-top:0.8rem;padding:1rem;
  background:rgba(2,12,27,0.85);border:1px solid rgba(0,212,255,0.12);
  border-radius:var(--radius-sm);display:flex;gap:0.9rem;align-items:flex-start;font-size:0.8rem;
}
.detail-icon{width:38px;height:38px;border-radius:10px;background:rgba(0,212,255,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.detail-icon svg{width:18px;height:18px;stroke:var(--cyan-400);fill:none;stroke-width:1.8}
.detail-text-title{font-family:'Oxanium',sans-serif;font-weight:700;font-size:0.84rem;color:var(--text);margin-bottom:0.25rem}
.detail-text-body{color:var(--muted-bright);line-height:1.55;font-size:0.77rem}

/* ─── MINI BARS ─── */
.mini-dash{margin-top:0.7rem}
.mini-row{display:flex;align-items:center;gap:0.6rem;margin-bottom:0.45rem;font-size:0.72rem}
.mini-label{flex:0 0 80px;color:var(--muted);font-family:'Rajdhani',sans-serif}
.mini-val{color:var(--text);font-weight:600;flex:0 0 44px;text-align:right}
.mini-bar-track{flex:1;height:4px;border-radius:999px;background:rgba(255,255,255,0.06);overflow:hidden}
.mini-bar-fill{height:100%;border-radius:999px;background:linear-gradient(90deg,var(--cyan-500),var(--teal-400));transition:width 0.6s cubic-bezier(0.16,1,0.3,1)}

/* ─── STATUS ROW ─── */
.status-row{display:flex;flex-wrap:wrap;gap:0.55rem;margin-top:0.8rem;align-items:center}
.status-pill{
  display:inline-flex;align-items:center;gap:0.4rem;
  padding:0.28rem 0.75rem;border-radius:999px;
  background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);
  font-size:0.68rem;color:var(--muted-bright);white-space:nowrap;
  font-family:'Rajdhani',sans-serif;
}
.status-pill strong{color:var(--text)}

/* ─── THREATS ─── */
.threats-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:0.8rem;flex-wrap:wrap;gap:0.5rem}
.threats-title{font-family:'Oxanium',sans-serif;font-weight:700;font-size:0.95rem}
.filter-pills{display:flex;gap:0.3rem;flex-wrap:wrap}
.filter-pill{
  padding:0.2rem 0.6rem;border-radius:999px;font-size:0.63rem;cursor:pointer;
  border:1px solid rgba(255,255,255,0.15);background:transparent;color:var(--muted-bright);
  transition:all 0.15s;text-transform:uppercase;letter-spacing:0.05em;font-family:'Rajdhani',sans-serif;font-weight:600;
}
.filter-pill:hover{border-color:rgba(0,212,255,0.4);color:var(--cyan-400)}
.filter-pill.active{background:rgba(0,212,255,0.15);border-color:rgba(0,212,255,0.5);color:var(--cyan-400)}
.filter-pill.fp-low.active{background:rgba(52,211,153,0.12);border-color:var(--green-400);color:var(--green-400)}
.filter-pill.fp-medium.active{background:rgba(251,191,36,0.12);border-color:var(--amber-400);color:var(--amber-400)}
.filter-pill.fp-high.active{background:rgba(248,113,113,0.12);border-color:var(--red-400);color:var(--red-400)}
.filter-pill.fp-critical.active{background:rgba(251,113,133,0.12);border-color:var(--rose-400);color:var(--rose-400)}
.legend{display:flex;gap:0.75rem;margin-bottom:0.65rem;flex-wrap:wrap;align-items:center}
.legend-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.legend-item{display:flex;align-items:center;gap:0.25rem;font-size:0.63rem;color:var(--muted-bright);font-family:'Rajdhani',sans-serif}
.incidents-feed{height:380px;overflow-y:auto;overflow-x:hidden;padding-right:0.3rem;scrollbar-width:thin;scrollbar-color:rgba(0,212,255,0.3) transparent}
.incidents-feed::-webkit-scrollbar{width:4px}
.incidents-feed::-webkit-scrollbar-thumb{background:rgba(0,212,255,0.3);border-radius:4px}
.incident-card{
  padding:0.9rem;border-radius:10px;border:1px solid rgba(255,255,255,0.05);
  margin-bottom:0.55rem;border-left:3px solid transparent;
  transition:all 0.15s;background:rgba(255,255,255,0.015);
  animation:slideIn 0.3s ease both;
}
@keyframes slideIn{from{opacity:0;transform:translateX(8px)}to{opacity:1;transform:translateX(0)}}
.incident-card.sev-low{border-left-color:var(--green-400)}.incident-card.sev-medium{border-left-color:var(--amber-400)}.incident-card.sev-high{border-left-color:var(--red-400)}.incident-card.sev-critical{border-left-color:var(--rose-400)}
.incident-card:hover{background:rgba(0,212,255,0.04);border-color:rgba(0,212,255,0.18)}
.inc-header{display:flex;justify-content:space-between;align-items:center;gap:0.5rem}
.inc-id{font-family:'Oxanium',sans-serif;font-weight:700;font-size:0.78rem}
.inc-mitre{font-size:0.6rem;color:var(--muted);font-family:'IBM Plex Mono',monospace}
.risk-badge{display:inline-flex;align-items:center;padding:0.14rem 0.55rem;border-radius:999px;font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;border:1px solid transparent;font-family:'Rajdhani',sans-serif}
.risk-badge.low{background:rgba(52,211,153,0.12);border-color:rgba(52,211,153,0.35);color:var(--green-400)}
.risk-badge.medium{background:rgba(251,191,36,0.12);border-color:rgba(251,191,36,0.35);color:var(--amber-400)}
.risk-badge.high{background:rgba(248,113,113,0.12);border-color:rgba(248,113,113,0.35);color:var(--red-400)}
.risk-badge.critical{background:rgba(251,113,133,0.14);border-color:rgba(251,113,133,0.4);color:var(--rose-400)}
.inc-tags{display:flex;gap:0.35rem;flex-wrap:wrap;margin-top:0.45rem}
.inc-tag{font-size:0.62rem;padding:0.13rem 0.5rem;border-radius:999px;background:rgba(0,212,255,0.08);border:1px solid rgba(0,212,255,0.18);color:var(--cyan-300);font-family:'Rajdhani',sans-serif}
.inc-meta{font-size:0.6rem;color:var(--muted);margin-top:0.38rem;font-family:'IBM Plex Mono',monospace}

/* ─── WORKSPACE ─── */
.workspace{margin-top:1rem;animation:fadeUp 0.7s 0.35s cubic-bezier(0.16,1,0.3,1) both}
.ws-header{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:0.5rem;margin-bottom:1rem}
.ws-title{font-family:'Oxanium',sans-serif;font-weight:700;font-size:1.05rem;color:var(--text)}
.ws-subtitle{font-size:0.7rem;color:var(--muted);margin-top:0.2rem;font-family:'Rajdhani',sans-serif}
.ws-badge-row{display:flex;gap:0.4rem;flex-wrap:wrap;align-items:center}
.ws-badge{
  font-size:0.62rem;padding:0.2rem 0.65rem;border-radius:4px;
  background:rgba(0,212,255,0.06);border:1px solid rgba(0,212,255,0.18);
  color:var(--cyan-300);font-family:'Rajdhani',sans-serif;font-weight:600;letter-spacing:0.05em;
}
.ws-tabs{display:flex;flex-wrap:wrap;gap:0.3rem;margin-bottom:0.75rem}
.ws-tab{
  padding:0.32rem 0.72rem;border-radius:999px;
  background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);
  font-size:0.68rem;color:var(--muted-bright);cursor:pointer;transition:all 0.15s;
  font-family:'Rajdhani',sans-serif;font-weight:600;letter-spacing:0.04em;
}
.ws-tab:hover{border-color:rgba(0,212,255,0.3);color:var(--cyan-400)}
.ws-tab[aria-selected="true"]{background:linear-gradient(135deg,rgba(0,212,255,0.18),rgba(45,212,191,0.12));border-color:rgba(0,212,255,0.5);color:var(--cyan-400)}
.ws-panel{padding:1rem 1.1rem;background:rgba(2,12,27,0.92);border:1px solid rgba(0,212,255,0.12);border-radius:12px;font-size:0.82rem}
.ws-panel[hidden]{display:none}
.ws-panel-title{font-family:'Oxanium',sans-serif;font-weight:700;font-size:0.88rem;margin-bottom:0.85rem;color:var(--text);display:flex;align-items:center;gap:0.5rem}
.ws-panel-title span{width:3px;height:14px;background:var(--cyan-500);border-radius:2px;display:inline-block}
.ws-form-row{display:flex;flex-wrap:wrap;gap:0.7rem;margin-bottom:0.75rem}
.ws-form-row label{display:flex;flex-direction:column;gap:0.3rem;font-size:0.67rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.07em;font-family:'Rajdhani',sans-serif;font-weight:600}
.ws-form-row input,.ws-form-row select,.ws-form-row textarea{
  background:rgba(10,22,40,0.95);border:1px solid rgba(0,212,255,0.2);border-radius:8px;
