  scrollbar-width:thin;scrollbar-color:rgba(0,212,255,0.2) transparent;
  line-height:1.6;
}
.ws-table{width:100%;border-collapse:collapse;margin-top:0.5rem;font-size:0.7rem}
.ws-table th{color:var(--cyan-400);font-weight:700;padding:0.35rem 0.45rem;text-align:left;border-bottom:1px solid rgba(0,212,255,0.18);font-family:'Rajdhani',sans-serif;letter-spacing:0.06em;font-size:0.65rem;text-transform:uppercase}
.ws-table td{padding:0.3rem 0.45rem;border-bottom:1px solid rgba(255,255,255,0.04);font-family:'IBM Plex Mono',monospace;font-size:0.68rem}

/* ─── MITRE HEATMAP ─── */
.mitre-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(90px,1fr));gap:4px;margin-top:0.5rem}
.mitre-cell{
  padding:0.5rem 0.4rem;border-radius:6px;text-align:center;
  font-size:0.6rem;font-family:'Rajdhani',sans-serif;font-weight:600;
  cursor:pointer;transition:all 0.15s;border:1px solid transparent;letter-spacing:0.03em;
}
.mitre-cell:hover{transform:scale(1.04);border-color:rgba(0,212,255,0.4)}
.mitre-cell.heat-0{background:rgba(0,212,255,0.04);color:var(--muted)}
.mitre-cell.heat-1{background:rgba(52,211,153,0.15);color:var(--green-400)}
.mitre-cell.heat-2{background:rgba(251,191,36,0.15);color:var(--amber-400)}
.mitre-cell.heat-3{background:rgba(248,113,113,0.2);color:var(--red-400)}
.mitre-cell.heat-4{background:rgba(251,113,133,0.25);color:var(--rose-400)}

/* ─── COMPLIANCE GAUGES ─── */
.compliance-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem;margin-top:0.5rem}
.compliance-item{text-align:center;padding:0.8rem 0.5rem;background:rgba(255,255,255,0.02);border-radius:10px;border:1px solid rgba(0,212,255,0.1)}
.compliance-name{font-family:'Rajdhani',sans-serif;font-weight:700;font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted-bright);margin-bottom:0.5rem}
.compliance-ring{position:relative;width:70px;height:70px;margin:0 auto 0.5rem}
.compliance-ring svg{transform:rotate(-90deg)}
.compliance-pct{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:'Oxanium',sans-serif;font-weight:800;font-size:0.9rem;color:var(--cyan-400)}

/* ─── AI ANALYST ─── */
.ai-chat-area{
  background:rgba(2,12,27,1);border:1px solid rgba(0,212,255,0.15);
  border-radius:10px;padding:0.8rem;max-height:250px;overflow-y:auto;
  margin-bottom:0.7rem;font-size:0.78rem;
  scrollbar-width:thin;scrollbar-color:rgba(0,212,255,0.2) transparent;
}
.ai-msg{margin-bottom:0.75rem;animation:slideIn 0.25s ease both}
.ai-msg.user .ai-bubble{background:rgba(0,212,255,0.1);border:1px solid rgba(0,212,255,0.2);border-radius:10px 10px 2px 10px;padding:0.6rem 0.85rem;color:var(--text);font-family:'IBM Plex Mono',monospace;font-size:0.74rem;text-align:right}
.ai-msg.assistant .ai-bubble{background:rgba(45,212,191,0.08);border:1px solid rgba(45,212,191,0.2);border-radius:10px 10px 10px 2px;padding:0.6rem 0.85rem;color:var(--text);font-family:'IBM Plex Mono',monospace;font-size:0.74rem;line-height:1.6}
.ai-msg-label{font-size:0.6rem;color:var(--muted);margin-bottom:0.2rem;font-family:'Rajdhani',sans-serif;font-weight:600;letter-spacing:0.08em;text-transform:uppercase}
.ai-msg.user .ai-msg-label{text-align:right}
.ai-input-row{display:flex;gap:0.5rem;align-items:center}
.ai-input{flex:1;background:rgba(10,22,40,0.95);border:1px solid rgba(0,212,255,0.2);border-radius:8px;padding:0.5rem 0.75rem;color:var(--text);font-size:0.78rem;font-family:'IBM Plex Mono',monospace;outline:none;transition:border-color 0.15s}
.ai-input:focus{border-color:rgba(0,212,255,0.5);box-shadow:var(--focus)}
.ai-key-row{display:flex;gap:0.5rem;margin-bottom:0.6rem;align-items:center}
.ai-key-input{flex:1;background:rgba(10,22,40,0.95);border:1px solid rgba(251,191,36,0.25);border-radius:8px;padding:0.42rem 0.65rem;color:var(--text);font-size:0.72rem;font-family:'IBM Plex Mono',monospace;outline:none;transition:border-color 0.15s}
.ai-key-input:focus{border-color:rgba(251,191,36,0.5)}
.ai-key-label{font-size:0.63rem;color:var(--gold-300);font-family:'Rajdhani',sans-serif;font-weight:600;letter-spacing:0.06em;white-space:nowrap}
.ai-typing{display:flex;align-items:center;gap:4px;padding:0.6rem 0.85rem}
.ai-typing span{width:6px;height:6px;border-radius:50%;background:var(--teal-400);animation:bounce 1s ease-in-out infinite}
.ai-typing span:nth-child(2){animation-delay:0.15s}.ai-typing span:nth-child(3){animation-delay:0.3s}
@keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-6px)}}

/* ─── BUTTONS ─── */
button{font-family:'Rajdhani',sans-serif;cursor:pointer;border:none;transition:all 0.15s ease;user-select:none;font-weight:600}
.btn{display:inline-flex;align-items:center;gap:0.45rem;padding:0.65rem 1.15rem;border-radius:10px;font-size:0.78rem;letter-spacing:0.04em;border:1px solid transparent}
.btn:hover{filter:brightness(1.1);transform:translateY(-1px)}.btn:active{transform:translateY(0);filter:brightness(0.95)}
.btn:focus-visible{outline:none;box-shadow:var(--focus)}.btn[disabled]{opacity:0.5;cursor:not-allowed;pointer-events:none}
.btn-primary{background:linear-gradient(135deg,rgba(0,212,255,0.9),rgba(45,212,191,0.85));color:var(--navy-950);font-weight:700}
.btn-secondary{background:rgba(0,212,255,0.1);border-color:rgba(0,212,255,0.35);color:var(--cyan-400)}
.btn-success{background:linear-gradient(135deg,rgba(52,211,153,0.9),rgba(16,185,129,0.85));color:var(--navy-950);font-weight:700}
.btn-ghost{background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.12);color:var(--muted-bright)}
.btn-gold{background:linear-gradient(135deg,rgba(245,158,11,0.85),rgba(251,191,36,0.8));color:var(--navy-950);font-weight:700}
.btn svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2;flex-shrink:0}

/* ─── CTA BAR ─── */
.cta-bar{display:flex;flex-wrap:wrap;gap:0.65rem;justify-content:center;margin-top:1rem;animation:fadeUp 0.7s 0.45s cubic-bezier(0.16,1,0.3,1) both;padding:1.4rem;background:var(--card-bg);border:1px solid var(--card-border);border-radius:var(--radius);box-shadow:var(--shadow-card)}
.cta-label{font-family:'Rajdhani',sans-serif;font-size:0.68rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);display:flex;align-items:center;gap:0.5rem;width:100%;justify-content:center;margin-bottom:0.3rem}
.cta-bar .btn{padding:0.8rem 1.5rem;font-size:0.82rem}

/* ─── TOAST ─── */
#toast-container{position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;display:flex;flex-direction:column;gap:0.5rem;pointer-events:none}
.toast{display:flex;align-items:center;gap:0.6rem;padding:0.75rem 1.1rem;border-radius:10px;background:rgba(10,22,40,0.97);border:1px solid rgba(0,212,255,0.3);box-shadow:0 8px 24px rgba(0,0,0,0.55);font-size:0.78rem;color:var(--text);backdrop-filter:blur(14px);min-width:240px;pointer-events:auto;animation:toastIn 0.35s cubic-bezier(0.16,1,0.3,1) both;font-family:'Rajdhani',sans-serif;font-weight:600}
.toast.toast-exit{animation:toastOut 0.25s ease forwards}
@keyframes toastIn{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:translateX(0)}}
@keyframes toastOut{from{opacity:1;transform:translateX(0)}to{opacity:0;transform:translateX(30px)}}
.toast-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.toast-info .toast-dot{background:var(--cyan-400)}.toast-success .toast-dot{background:var(--green-400)}.toast-warn .toast-dot{background:var(--amber-400)}

/* ─── MODAL (ToS) ─── */
.modal-overlay{position:fixed;inset:0;z-index:8000;background:rgba(2,12,27,0.92);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;padding:2rem;animation:fadeIn 0.25s ease both}
.modal-overlay[hidden]{display:none}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.modal-box{background:rgba(10,22,40,0.99);border:1px solid rgba(0,212,255,0.25);border-radius:var(--radius);padding:2rem;max-width:720px;width:100%;max-height:80vh;overflow-y:auto;box-shadow:0 24px 80px rgba(0,0,0,0.7);position:relative}
.modal-box::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--cyan-500),transparent)}
.modal-title{font-family:'Oxanium',sans-serif;font-weight:800;font-size:1.3rem;margin-bottom:0.3rem;background:linear-gradient(90deg,var(--text),var(--cyan-400));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.modal-subtitle{font-size:0.7rem;color:var(--muted);font-family:'Rajdhani',sans-serif;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:1.5rem}
.modal-section{margin-bottom:1.2rem}
.modal-section h3{font-family:'Rajdhani',sans-serif;font-weight:700;font-size:0.8rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--cyan-400);margin-bottom:0.5rem}
.modal-section p,.modal-section li{font-size:0.78rem;color:var(--muted-bright);line-height:1.65;font-family:'IBM Plex Mono',monospace}
.modal-section ul{padding-left:1.2rem}
.modal-section li{margin-bottom:0.3rem}
.modal-footer{display:flex;justify-content:flex-end;gap:0.6rem;margin-top:1.5rem;padding-top:1rem;border-top:1px solid rgba(0,212,255,0.12)}

/* ─── FOOTER ─── */
.footer{text-align:center;font-size:0.63rem;color:var(--muted);margin-top:1.5rem;padding:1.2rem;border-top:1px solid rgba(255,255,255,0.05);letter-spacing:0.05em;font-family:'Rajdhani',sans-serif;line-height:1.8}
.footer a{color:var(--cyan-400);text-decoration:none;opacity:0.7}
.footer .footer-brand{font-family:'Oxanium',sans-serif;font-weight:700;color:var(--text);font-size:0.75rem;margin-bottom:0.3rem;display:block}

/* ─── RESPONSIVE ─── */
@media(max-width:1200px){.main-grid{grid-template-columns:1fr}.incidents-feed{height:300px}}
@media(max-width:900px){.metrics-grid{grid-template-columns:repeat(2,1fr)}.chart-row{grid-template-columns:1fr}.compliance-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.layout{padding:1rem}.metrics-grid{grid-template-columns:1fr}.cta-bar .btn{width:100%;justify-content:center}.mitre-grid{grid-template-columns:repeat(3,1fr)}}
.sr-only{position:absolute!important;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
</style>
