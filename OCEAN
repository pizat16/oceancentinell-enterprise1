/* ── OCEAN CANVAS ── */
const canvas = document.getElementById('ocean-canvas');
const ctx = canvas.getContext('2d');
let W, H;
function resizeCanvas(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight}
resizeCanvas();window.addEventListener('resize',resizeCanvas);
const waves=[
  {amp:30,period:0.005,speed:0.0007,phase:0,color:'rgba(0,212,255,0.035)'},
  {amp:20,period:0.008,speed:0.0011,phase:2.1,color:'rgba(45,212,191,0.028)'},
  {amp:14,period:0.012,speed:0.0016,phase:4.5,color:'rgba(0,212,255,0.02)'},
];
function drawOcean(){
  ctx.clearRect(0,0,W,H);
  waves.forEach(w=>{
    w.phase+=w.speed;
    ctx.beginPath();ctx.moveTo(0,H*0.6);
    for(let x=0;x<=W;x+=4){
      const y=H*0.6+Math.sin(x*w.period+w.phase)*w.amp+Math.sin(x*w.period*1.8+w.phase*0.7)*(w.amp*0.35);
      ctx.lineTo(x,y);
    }
    ctx.lineTo(W,H);ctx.lineTo(0,H);ctx.closePath();
    ctx.fillStyle=w.color;ctx.fill();
  });
  requestAnimationFrame(drawOcean);
}
drawOcean();

/* ── CLOCK ── */
const clockEl=document.getElementById('clockEl');
const clockDate=document.getElementById('clockDate');
